{
  "name": "account-management-system",
  "version": "1.0.0",
  "description": "Account Management System - Modernized from COBOL to Node.js",
  "main": "src/accounting/index.js",
  "scripts": {
    "start": "node src/accounting/index.js",
    "dev": "node --inspect-brk src/accounting/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["accounting", "cobol", "nodejs", "modernization"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "prompt-sync": "^4.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js", "!src/**/*.test.js"]
  }
}
